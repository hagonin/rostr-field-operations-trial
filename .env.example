# Copy to .env.local and fill in your Supabase project values.
# 1. Create a project at https://supabase.com
# 2. Run supabase/schema.sql in the SQL editor
# 3. Run supabase/seed.sql in the SQL editor
# 4. Paste values from Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — keep server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Shared passcode for the admin area gate — server-side only
ADMIN_PASSCODE=your-admin-passcode-here
